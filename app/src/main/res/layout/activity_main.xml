<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/wallpaper"
            android:scaleType="centerCrop"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="61dp"
            android:background="#803D8AEB"
            android:gravity="center"
            android:text="Thông tin truyện"
            android:textAlignment="center"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên truyện/sách: "
                android:textColor="#ff2400"
                android:textSize="19sp" />

            <EditText
                android:id="@+id/edtName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/khung"
                android:ems="10"
                android:inputType="text"
                android:textAlignment="center"
                android:textColor="#ff2400"
                android:textColorHighlight="#CB27A4F2"
                android:textSize="19sp"
                android:padding="1dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên tác giả: "
                android:textColor="#ff2400"
                android:textSize="19sp" />

            <EditText
                android:id="@+id/edtTG"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/khung"
                android:ems="10"
                android:inputType="text"
                android:padding="1dp"
                android:textAlignment="center"
                android:textColor="#ff2400"
                android:textSize="19sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tập số:"
                android:textColor="#ff2400"
                android:textSize="19sp" />

            <EditText
                android:id="@+id/edtChap"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/khung"
                android:ems="10"
                android:inputType="number"
                android:padding="1dp"
                android:textAlignment="center"
                android:textColor="#ff2400"
                android:textSize="19sp" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giá tiền:"
                android:textColor="#ff2400"
                android:textSize="19sp" />

            <EditText
                android:id="@+id/edtGia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/khung"
                android:ems="10"
                android:inputType="number"
                android:padding="1dp"
                android:textAlignment="center"
                android:textColor="#ff2400"
                android:textSize="19sp" />

            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tái bản"
                android:textColor="#ff2400"
                android:textSize="19sp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/edtTB"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ems="10"
                android:inputType="number"
                android:textAlignment="center"
                android:textColor="#ff2400"
                android:textSize="19sp"
                android:visibility="gone"
                tools:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btninsert"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#503D8AEB"
                android:text="Thêm truyện"
                android:textColor="@color/white"
                android:textColorHighlight="#000000"
                android:textSize="19sp" />

            <Button
                android:id="@+id/btnsearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#503D8AEB"
                android:text="Tìm truyện"
                android:textColor="@color/white"
                android:textSize="19sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnupdate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#503D8AEB"
                android:text="Cập nhật"
                android:textColor="@color/white"
                android:textSize="19sp" />

            <Button
                android:id="@+id/btnshow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#503D8AEB"
                android:text="Danh sách"
                android:textColor="@color/white"
                android:textSize="19sp" />

        </LinearLayout>

        <ListView
            android:id="@+id/lv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:divider="@android:color/transparent"
            android:dividerHeight="2dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>